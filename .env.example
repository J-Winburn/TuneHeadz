# Leave these blank, make a copy of this file and add your own credentials
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/spotify
NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=your-own-random-secret

# Supabase (email/password auth) — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Spotify playlist that powers the landing carousel (override default “Top Albums - Global”).
# If unset or invalid, the API tries Top 50 — Global and Top Songs — Global as fallbacks.
# BILLBOARD_CAROUSEL_PLAYLIST_ID=

# Optional: override Figma embed on /design (defaults to Tune Headz file below if unset)
# NEXT_PUBLIC_FIGMA_EMBED_URL=https://embed.figma.com/design/7SYur77AEdCZCqoi42basB/Tune-Headz?node-id=0-1&embed-host=share
